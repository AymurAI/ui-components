{
  "name": "@aymurai/ui",
  "version": "0.4.0",
  "description": "AymurAI shared React component library, extracted from the Figma UI Library and authored with Panda CSS.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./fonts.css": "./dist/fonts.css",
    "./preset": {
      "types": "./dist/preset.d.ts",
      "import": "./dist/preset.js",
      "require": "./dist/preset.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "prepare": "husky && pnpm build",
    "codegen": "panda codegen",
    "cssgen": "panda cssgen --silent --outfile dist/styles.css",
    "build": "pnpm codegen && tsc -p tsconfig.build.json && vite build && pnpm cssgen && cp src/styles/fonts.css dist/fonts.css",
    "dev": "storybook dev -p 6006",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "validate": "pnpm lint && pnpm typecheck",
    "release": "pnpm build && pnpm pack --pack-destination ."
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "phosphor-react": "^1.4.1",
    "react-hot-toast": "^2.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@pandacss/dev": "^1.8.1",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.4.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "react": "^19",
    "react-dom": "^19",
    "storybook": "^8.4.0",
    "typescript": "^5.9.2",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.3.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AymurAI/ui-components.git"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,jsx,tsx,json,jsonc,css}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
